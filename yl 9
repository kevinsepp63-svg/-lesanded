# Küsi kasutajalt kolme külje pikkused
a = float(input("Sisesta külg a: "))
b = float(input("Sisesta külg b: "))
c = float(input("Sisesta külg c: "))

# Kontrolli, kas kolmnurk saab eksisteerida
if a + b > c and a + c > b and b + c > a:
    print("Kolmnurk saab eksisteerida.")

    # Liigitamine külgede järgi
    if a == b == c:
        print("Kolmnurk on võrdkülgne.")
    elif a == b or a == c or b == c:
        print("Kolmnurk on võrdhaarne.")
    else:
        print("Kolmnurk on erikülgne.")
else:
    print("Selliste külgedega kolmnurk ei saa eksisteerida.")
