# Küsi kasutajalt nimi ja tervita teda
nimi = input("Sisesta oma nimi: ")
print("Tere, " + nimi + "!")

# Küsi kasutajalt elukoht ja reageeri vastusele
elukoht = input("Sisesta oma elukoht: ")

if elukoht.lower() == "saaremaa":
    print("Saaremaal on väga ilus loodus!")

# Küsi kasutajalt vanus ja reageeri vastusele
vanus = int(input("Sisesta oma vanus: "))

if vanus < 18:
    print("Sa oled liiga noor, et autot juhtida.")
elif vanus == 18:
    print("Palju õnne täisealiseks saamise puhul!")
else:
    print("Sa võid autot juhtida.")
